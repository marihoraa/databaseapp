DROP DATABASE IF EXISTS aula_olap;
CREATE DATABASE aula_olap CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci;

USE aula_olap;

CREATE TABLE dim_tempo (
    id_tempo INT PRIMARY KEY,
    data_completa DATE NOT NULL,
    ano SMALLINT NOT NULL,
    semestre TINYINT NOT NULL,
    trimestre TINYINT NOT NULL,
    mes TINYINT NOT NULL,
    nome_mes VARCHAR(20) NOT NULL,
    dia TINYINT NOT NULL,
    dia_semana TINYINT NOT NULL,
    fim_de_semana CHAR(1) NOT NULL
) ENGINE=InnoDB;

CREATE TABLE dim_cliente (
    id_cliente_sk BIGINT PRIMARY KEY AUTO_INCREMENT,
    id_cliente_nk BIGINT NOT NULL,
    nome_cliente VARCHAR(120) NOT NULL,
    cidade VARCHAR(80),
    estado CHAR(2),
    status_cliente VARCHAR(20),
    dt_inicio_vigencia DATE NOT NULL,
    dt_fim_vigencia DATE,
    registro_ativo CHAR(1) NOT NULL DEFAULT 'S'
) ENGINE=InnoDB;

CREATE TABLE dim_produto (
    id_produto_sk BIGINT PRIMARY KEY AUTO_INCREMENT,
    id_produto_nk BIGINT NOT NULL,
    nome_produto VARCHAR(120) NOT NULL,
    categoria VARCHAR(100) NOT NULL,
    preco_lista DECIMAL(12,2) NOT NULL,
    status_produto VARCHAR(20),
    dt_inicio_vigencia DATE NOT NULL,
    dt_fim_vigencia DATE,
    registro_ativo CHAR(1) NOT NULL DEFAULT 'S'
) ENGINE=InnoDB;

CREATE TABLE fato_vendas (
    id_fato BIGINT PRIMARY KEY AUTO_INCREMENT,
    id_tempo INT NOT NULL,
    id_cliente_sk BIGINT NOT NULL,
    id_produto_sk BIGINT NOT NULL,
    id_pedido_nk BIGINT NOT NULL,
    quantidade INT NOT NULL,
    preco_unitario DECIMAL(12,2) NOT NULL,
    valor_bruto DECIMAL(12,2) NOT NULL,
    desconto_rateado DECIMAL(12,2) NOT NULL,
    frete_rateado DECIMAL(12,2) NOT NULL,
    valor_liquido DECIMAL(12,2) NOT NULL,
    FOREIGN KEY (id_tempo) REFERENCES dim_tempo(id_tempo),
    FOREIGN KEY (id_cliente_sk) REFERENCES dim_cliente(id_cliente_sk),
    FOREIGN KEY (id_produto_sk) REFERENCES dim_produto(id_produto_sk)
) ENGINE=InnoDB;

CREATE INDEX idx_fato_tempo ON fato_vendas(id_tempo);
CREATE INDEX idx_fato_cliente ON fato_vendas(id_cliente_sk);
CREATE INDEX idx_fato_produto ON fato_vendas(id_produto_sk);
CREATE INDEX idx_fato_pedido ON fato_vendas(id_pedido_nk);

INSERT INTO dim_tempo (
    id_tempo, data_completa, ano, semestre, trimestre, mes, nome_mes, dia, dia_semana, fim_de_semana
)
WITH RECURSIVE datas AS (
    SELECT DATE('2026-01-01') AS dt
    UNION ALL
    SELECT dt + INTERVAL 1 DAY
    FROM datas
    WHERE dt < DATE('2026-12-31')
)
SELECT
    DATE_FORMAT(dt, '%Y%m%d') + 0 AS id_tempo,
    dt AS data_completa,
    YEAR(dt) AS ano,
    CASE WHEN MONTH(dt) <= 6 THEN 1 ELSE 2 END AS semestre,
    QUARTER(dt) AS trimestre,
    MONTH(dt) AS mes,
    ELT(MONTH(dt),
        'Janeiro','Fevereiro','Março','Abril','Maio','Junho',
        'Julho','Agosto','Setembro','Outubro','Novembro','Dezembro') AS nome_mes,
    DAY(dt) AS dia,
    DAYOFWEEK(dt) AS dia_semana,
    CASE WHEN DAYOFWEEK(dt) IN (1,7) THEN 'S' ELSE 'N' END AS fim_de_semana
FROM datas;

INSERT INTO dim_cliente (
    id_cliente_nk, nome_cliente, cidade, estado, status_cliente,
    dt_inicio_vigencia, dt_fim_vigencia, registro_ativo
)
SELECT
    c.id_cliente,
    c.nome,
    c.cidade,
    c.estado,
    c.status_cliente,
    CURRENT_DATE(),
    NULL,
    'S'
FROM aula_oltp.clientes c;

INSERT INTO dim_produto (
    id_produto_nk, nome_produto, categoria, preco_lista, status_produto,
    dt_inicio_vigencia, dt_fim_vigencia, registro_ativo
)
SELECT
    p.id_produto,
    p.nome_produto,
    cat.nome_categoria,
    p.preco_unitario,
    p.status_produto,
    CURRENT_DATE(),
    NULL,
    'S'
FROM aula_oltp.produtos p
JOIN aula_oltp.categorias cat
    ON cat.id_categoria = p.id_categoria;

INSERT INTO fato_vendas (
    id_tempo, id_cliente_sk, id_produto_sk, id_pedido_nk,
    quantidade, preco_unitario, valor_bruto,
    desconto_rateado, frete_rateado, valor_liquido
)
SELECT
    DATE_FORMAT(DATE(pe.data_pedido), '%Y%m%d') + 0 AS id_tempo,
    dc.id_cliente_sk,
    dp.id_produto_sk,
    pe.id_pedido AS id_pedido_nk,
    ip.quantidade,
    ip.preco_unitario,
    (ip.quantidade * ip.preco_unitario) AS valor_bruto,

    COALESCE(ROUND(
        ((ip.quantidade * ip.preco_unitario) / NULLIF(tp.total_bruto_pedido, 0)) * pe.desconto
    , 2), 0) AS desconto_rateado,

    COALESCE(ROUND(
        ((ip.quantidade * ip.preco_unitario) / NULLIF(tp.total_bruto_pedido, 0)) * pe.frete
    , 2), 0) AS frete_rateado,

    COALESCE(ROUND(
        (ip.quantidade * ip.preco_unitario)
        - (((ip.quantidade * ip.preco_unitario) / NULLIF(tp.total_bruto_pedido, 0)) * pe.desconto)
        + (((ip.quantidade * ip.preco_unitario) / NULLIF(tp.total_bruto_pedido, 0)) * pe.frete)
    , 2), 0) AS valor_liquido

FROM aula_oltp.itens_pedido ip
JOIN aula_oltp.pedidos pe
    ON pe.id_pedido = ip.id_pedido
JOIN (
    SELECT
        id_pedido,
        SUM(quantidade * preco_unitario) AS total_bruto_pedido 
    FROM aula_oltp.itens_pedido
    GROUP BY id_pedido
) tp
    ON tp.id_pedido = pe.id_pedido
JOIN dim_cliente dc
    ON dc.id_cliente_nk = pe.id_cliente
   AND dc.registro_ativo = 'S'
JOIN dim_produto dp
    ON dp.id_produto_nk = ip.id_produto
   AND dp.registro_ativo = 'S'
WHERE pe.status_pedido <> 'CANCELADO';

SELECT
    t.ano,
    t.mes,
    t.nome_mes,
    SUM(f.valor_liquido) AS faturamento,
    SUM(f.quantidade) AS itens_vendidos
FROM fato_vendas f
JOIN dim_tempo t ON t.id_tempo = f.id_tempo
GROUP BY t.ano, t.mes, t.nome_mes
ORDER BY t.ano, t.mes;

SELECT
    p.nome_produto,
    p.categoria,
    SUM(f.quantidade) AS qtd_vendida,
    SUM(f.valor_liquido) AS receita_total
FROM fato_vendas f
JOIN dim_produto p ON p.id_produto_sk = f.id_produto_sk
GROUP BY p.nome_produto, p.categoria
ORDER BY receita_total DESC
LIMIT 10;

SELECT
    c.estado,
    p.categoria,
    SUM(f.valor_liquido) AS receita
FROM fato_vendas f
JOIN dim_cliente c ON c.id_cliente_sk = f.id_cliente_sk
JOIN dim_produto p ON p.id_produto_sk = f.id_produto_sk
GROUP BY c.estado, p.categoria
ORDER BY c.estado, receita DESC;

SELECT
    t.ano,
    t.mes,
    t.nome_mes,
    ROUND(SUM(f.valor_liquido) / COUNT(DISTINCT f.id_pedido_nk), 2) AS ticket_medio
FROM fato_vendas f
JOIN dim_tempo t ON t.id_tempo = f.id_tempo
GROUP BY t.ano, t.mes, t.nome_mes
ORDER BY t.ano, t.mes;
WITH receita_mensal AS (
    SELECT
        t.ano,
        t.mes,
        t.nome_mes,
        SUM(f.valor_liquido) AS faturamento
    FROM fato_vendas f
    JOIN dim_tempo t ON t.id_tempo = f.id_tempo
    GROUP BY t.ano, t.mes, t.nome_mes
)
SELECT
    ano,
    mes,
    nome_mes,
    faturamento,
    LAG(faturamento) OVER (ORDER BY ano, mes) AS faturamento_mes_anterior,
    ROUND(
        ( faturamento - LAG(faturamento) OVER (ORDER BY ano, mes)
        ) / NULLIF(LAG(faturamento) OVER (ORDER BY ano, mes), 0) * 100
    , 2) AS variacao_percentual
FROM receita_mensal
ORDER BY ano, mes;

SELECT
    p.categoria,
    t.nome_mes,
    SUM(f.valor_liquido) AS receita_total
FROM fato_vendas f
JOIN dim_produto p ON p.id_produto_sk = f.id_produto_sk
JOIN dim_tempo t ON t.id_tempo = f.id_tempo
GROUP BY p.categoria, t.nome_mes WITH ROLLUP;

SELECT
    p.nome_produto,
    SUM(f.quantidade) AS total_unidades
FROM fato_vendas f
JOIN dim_produto p ON p.id_produto_sk = f.id_produto_sk
GROUP BY p.nome_produto
ORDER BY total_unidades DESC;

SELECT
    c.nome_cliente,
    c.cidade,
    c.estado,
    SUM(f.valor_liquido) AS total_gasto
FROM fato_vendas f
JOIN dim_cliente c ON c.id_cliente_sk = f.id_cliente_sk
GROUP BY c.nome_cliente, c.cidade, c.estado
ORDER BY total_gasto DESC;

USE aula_oltp;

CREATE OR REPLACE VIEW vw_resumo_pedidos_oltp AS
SELECT
    p.id_pedido,
    c.nome AS cliente,
    p.data_pedido,
    p.status_pedido,
    p.valor_bruto,
    p.desconto,
    p.frete,
    p.valor_total
FROM pedidos p
JOIN clientes c ON c.id_cliente = p.id_cliente;

USE aula_olap;

CREATE OR REPLACE VIEW vw_faturamento_mensal_olap AS
SELECT
    t.ano,
    t.mes,
    t.nome_mes,
    SUM(f.valor_liquido) AS faturamento
FROM fato_vendas f
JOIN dim_tempo t ON t.id_tempo = f.id_tempo
GROUP BY t.ano, t.mes, t.nome_mes;

USE aula_oltp;
SELECT * FROM vw_resumo_pedidos_oltp ORDER BY data_pedido DESC;

USE aula_olap;
SELECT * FROM vw_faturamento_mensal_olap ORDER BY ano, mes;

DROP DATABASE IF EXISTS aula_oltp;
CREATE DATABASE aula_oltp CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci;

USE aula_oltp;

CREATE TABLE clientes (
    id_cliente BIGINT PRIMARY KEY AUTO_INCREMENT,
    nome VARCHAR(120) NOT NULL,
    email VARCHAR(150) NOT NULL UNIQUE,
    cpf CHAR(11) UNIQUE,
    telefone VARCHAR(20),
    cidade VARCHAR(80),
    estado CHAR(2),
    data_cadastro DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    status_cliente ENUM('ATIVO', 'INATIVO') NOT NULL DEFAULT 'ATIVO'
) ENGINE=InnoDB;

CREATE TABLE categorias (
    id_categoria BIGINT PRIMARY KEY AUTO_INCREMENT,
    nome_categoria VARCHAR(100) NOT NULL UNIQUE,
    descricao VARCHAR(255)
) ENGINE=InnoDB;

CREATE TABLE produtos (
    id_produto BIGINT PRIMARY KEY AUTO_INCREMENT,
    id_categoria BIGINT NOT NULL,
    nome_produto VARCHAR(120) NOT NULL,
    sku VARCHAR(40) NOT NULL UNIQUE,
    preco_unitario DECIMAL(12,2) NOT NULL,
    estoque_atual INT NOT NULL DEFAULT 0,
    status_produto ENUM('ATIVO', 'INATIVO') NOT NULL DEFAULT 'ATIVO',
    data_criacao DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT fk_produtos_categoria
        FOREIGN KEY (id_categoria) REFERENCES categorias(id_categoria)
) ENGINE=InnoDB;

CREATE TABLE pedidos (
    id_pedido BIGINT PRIMARY KEY AUTO_INCREMENT,
    id_cliente BIGINT NOT NULL,
    data_pedido DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    status_pedido ENUM('ABERTO', 'PAGO', 'SEPARACAO', 'ENVIADO', 'ENTREGUE', 'CANCELADO')
        NOT NULL DEFAULT 'ABERTO',
    valor_bruto DECIMAL(12,2) NOT NULL DEFAULT 0.00,
    desconto DECIMAL(12,2) NOT NULL DEFAULT 0.00,
    frete DECIMAL(12,2) NOT NULL DEFAULT 0.00,
    valor_total DECIMAL(12,2) NOT NULL DEFAULT 0.00,
    observacao VARCHAR(255),
    CONSTRAINT fk_pedidos_cliente
        FOREIGN KEY (id_cliente) REFERENCES clientes(id_cliente)
) ENGINE=InnoDB;

CREATE TABLE itens_pedido (
    id_item BIGINT PRIMARY KEY AUTO_INCREMENT,
    id_pedido BIGINT NOT NULL,
    id_produto BIGINT NOT NULL,
    quantidade INT NOT NULL,
    preco_unitario DECIMAL(12,2) NOT NULL,
    subtotal DECIMAL(12,2) GENERATED ALWAYS AS (quantidade * preco_unitario) STORED,
    CONSTRAINT fk_itens_pedido
        FOREIGN KEY (id_pedido) REFERENCES pedidos(id_pedido),
    CONSTRAINT fk_itens_produto
        FOREIGN KEY (id_produto) REFERENCES produtos(id_produto)
) ENGINE=InnoDB;

CREATE TABLE pagamentos (
    id_pagamento BIGINT PRIMARY KEY AUTO_INCREMENT,
    id_pedido BIGINT NOT NULL,
    data_pagamento DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    forma_pagamento ENUM('PIX', 'CARTAO', 'BOLETO', 'DINHEIRO') NOT NULL,
    valor_pago DECIMAL(12,2) NOT NULL,
    status_pagamento ENUM('PENDENTE', 'APROVADO', 'RECUSADO', 'ESTORNADO')
        NOT NULL DEFAULT 'PENDENTE',
    CONSTRAINT fk_pagamentos_pedido
        FOREIGN KEY (id_pedido) REFERENCES pedidos(id_pedido)
) ENGINE=InnoDB;

CREATE TABLE estoque_movimentacoes (
    id_movimentacao BIGINT PRIMARY KEY AUTO_INCREMENT,
    id_produto BIGINT NOT NULL,
    tipo_movimentacao ENUM('ENTRADA', 'SAIDA', 'AJUSTE') NOT NULL,
    quantidade INT NOT NULL,
    data_movimentacao DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    motivo VARCHAR(255),
    CONSTRAINT fk_estoque_produto
        FOREIGN KEY (id_produto) REFERENCES produtos(id_produto)
) ENGINE=InnoDB;

CREATE INDEX idx_clientes_nome ON clientes(nome);
