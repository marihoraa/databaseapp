CREATE DATABASE IF NOT EXISTS db_olap;
USE db_olap;

CREATE TABLE dim_tempo (
    id_tempo INT  PRIMARY KEY,
    data_completa DATE NOT NULL,
    ano INT  NOT NULL,
    semestre INT  NOT NULL,
    trimestre INT  NOT NULL,    
    mes INT  NOT NULL,   
    nome_mes VARCHAR(20) NOT NULL,
    semana INT  NOT NULL, 
    dia INT  NOT NULL,
    dia_semana VARCHAR(15) NOT NULL,
    eh_fim_semana TINYINT(1) NOT NULL
);


INSERT INTO dim_tempo (id_tempo, data_completa, ano, semestre, trimestre, mes, nome_mes, semana, dia, dia_semana, eh_fim_semana)
WITH RECURSIVE datas AS (
    SELECT CAST('2024-01-01' AS DATE) AS d
    UNION ALL
    SELECT DATE_ADD(d, INTERVAL 1 DAY)
    FROM datas
    WHERE d < '2024-12-31'
)
SELECT
    CAST(DATE_FORMAT(d, '%Y%m%d') AS UNSIGNED) AS id_tempo,
    d AS data_completa,
    YEAR(d) AS ano,
    IF(MONTH(d) <= 6, 1, 2) AS semestre,
    QUARTER(d) AS trimestre,
    MONTH(d) AS mes,
    DATE_FORMAT(d,'%M') AS nome_mes,
    WEEK(d, 1) AS semana,
    DAY(d) AS dia,
    DATE_FORMAT(d,'%W') AS dia_semana,
    IF(DAYOFWEEK(d) IN (1,7), 1, 0) AS eh_fim_semana
FROM datas;

