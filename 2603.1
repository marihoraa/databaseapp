SELECT
    p.id_pedido,
    c.nome AS cliente,
    v.nome AS vendedor,
    p.data_pedido,
    p.status,
    pr.nome AS produto,
    ip.quantidade,
    ip.preco_vendido,
    (ip.quantidade * ip.preco_vendido) AS subtotal
FROM pedido p
JOIN cliente c ON c.id_cliente  = p.id_cliente
JOIN vendedor v ON v.id_vendedor = p.id_vendedor
JOIN item_pedido ip ON ip.id_pedido = p.id_pedido
JOIN produto pr ON pr.id_produto = ip.id_produto
WHERE p.id_pedido = 1;

SELECT nome, estoque, preco_unitario
FROM produto
WHERE id_produto = 1;

SELECT
    p.id_pedido,
    c.nome AS cliente,
    p.data_pedido,
    p.status
FROM pedido p
JOIN cliente c ON c.id_cliente = p.id_cliente
WHERE p.status IN ('pendente', 'confirmado')
ORDER BY p.data_pedido;

