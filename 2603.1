INSERT INTO dim_cliente (id_cliente_nk, nome_cliente, estado)
SELECT id_cliente, nome, estado FROM aula_oltp.clientes;

INSERT INTO dim_produto (id_produto_nk, nome_produto, categoria)
SELECT p.id_produto, p.nome_produto, c.nome_categoria
FROM aula_oltp.produtos p
INNER JOIN aula_oltp.categorias c ON p.id_categoria = c.id_categoria;

INSERT INTO fato_vendas (id_tempo, id_cliente_sk, id_produto_sk, quantidade, valor_liquido)
SELECT 
    DATE_FORMAT(pe.data_pedido, '%Y%m%d') + 0,
    dc.id_cliente_sk,
    dp.id_produto_sk,
    ip.quantidade,
    ROUND((ip.subtotal) - (ip.subtotal / res.total_pedido * pe.desconto) + (ip.subtotal / res.total_pedido * pe.frete), 2)
FROM aula_oltp.itens_pedido ip
INNER JOIN aula_oltp.pedidos pe ON ip.id_pedido = pe.id_pedido
INNER JOIN (
    SELECT id_pedido, SUM(subtotal) as total_pedido 
    FROM aula_oltp.itens_pedido GROUP BY id_pedido
) res ON pe.id_pedido = res.id_pedido
INNER JOIN dim_cliente dc ON pe.id_cliente = dc.id_cliente_nk
INNER JOIN dim_produto dp ON ip.id_produto = dp.id_produto_nk
WHERE pe.status_pedido <> 'CANCELADO';

SELECT 
    t.nome_mes, 
    COALESCE(SUM(f.valor_liquido), 0) AS faturamento
FROM dim_tempo t
LEFT JOIN fato_vendas f ON t.id_tempo = f.id_tempo
GROUP BY t.id_tempo, t.nome_mes
ORDER BY t.id_tempo;

SELECT 
    p.nome_produto, 
    COALESCE(SUM(f.quantidade), 0) AS total_vendido
FROM dim_produto p
LEFT JOIN fato_vendas f ON p.id_produto_sk = f.id_produto_sk
GROUP BY p.id_produto_sk, p.nome_produto
ORDER BY total_vendido DESC;

SELECT 
    c.nome_cliente, 
    COALESCE(SUM(f.valor_liquido), 0) AS total_gasto
FROM dim_cliente c
LEFT JOIN fato_vendas f ON c.id_cliente_sk = f.id_cliente_sk
GROUP BY c.id_cliente_sk, c.nome_cliente
ORDER BY total_gasto DESC;

SELECT 
    f.id_fato,
    t.data_completa,
    c.nome_cliente,
    p.nome_produto,
    f.valor_liquido
FROM fato_vendas f
INNER JOIN dim_tempo t   ON f.id_tempo = t.id_tempo
INNER JOIN dim_cliente c ON f.id_cliente_sk = c.id_cliente_sk
INNER JOIN dim_produto p ON f.id_produto_sk = p.id_produto_sk;

/* Estas consultas foram refatoradas a partir do LEFT JOIN, partindo de suas respectivas dimensões. O LEFT JOIN aplicado também garantirá
que o mês, produto ou cliente permaneça sendo exibido na lista mesmo que o valor da venda seja equivalente a zero.
Além disso, o uso de INNER JOINS com tabelas derivadas permite o cálculo entre: peso e total do pedido, agregando o frete e desconto.
*/
