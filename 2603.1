CREATE TABLE fato_vendas (
    id_fato BIGINT AUTO_INCREMENT PRIMARY KEY,
    id_tempo INT NOT NULL,
    id_produto INT NOT NULL,
    id_cliente INT NOT NULL,
    id_vendedor INT NOT NULL,
    id_pedido INT NOT NULL,
    quantidade INT NOT NULL,
    preco_unitario DECIMAL(10,2) NOT NULL,
    valor_total DECIMAL(12,2) NOT NULL, 
    INDEX idx_tempo (id_tempo),
    INDEX idx_produto (id_produto),
    INDEX idx_cliente (id_cliente),
    INDEX idx_vendedor (id_vendedor),
    CONSTRAINT fk_ft_tempo FOREIGN KEY (id_tempo) REFERENCES dim_tempo(id_tempo),
    CONSTRAINT fk_ft_prod FOREIGN KEY (id_produto) REFERENCES dim_produto(id_produto),
    CONSTRAINT fk_ft_cli FOREIGN KEY (id_cliente)  REFERENCES dim_cliente(id_cliente),
    CONSTRAINT fk_ft_vend FOREIGN KEY (id_vendedor) REFERENCES dim_vendedor(id_vendedor)
);

