SELECT
    t.ano,
    t.mes,
    t.nome_mes,
    COUNT(DISTINCT fv.id_pedido) AS qtd_pedidos,
    SUM(fv.quantidade) AS unidades_vendidas,
    SUM(fv.valor_total) AS receita_total
FROM fato_vendas fv
JOIN dim_tempo t ON t.id_tempo = fv.id_tempo
GROUP BY t.ano, t.mes, t.nome_mes
ORDER BY t.ano, t.mes;

SELECT
    p.categoria,
    t.trimestre,
    SUM(fv.valor_total) AS receita,
    SUM(fv.quantidade) AS unidades
FROM fato_vendas fv
JOIN dim_produto p ON p.id_produto = fv.id_produto
JOIN dim_tempo t ON t.id_tempo = fv.id_tempo
GROUP BY p.categoria, t.trimestre
ORDER BY p.categoria, t.trimestre;

SELECT
    p.nome_produto,
    p.categoria,
    p.faixa_preco,
    SUM(fv.valor_total) AS receita_total,
    SUM(fv.quantidade) AS unidades_vendidas,
    RANK() OVER (ORDER BY SUM(fv.valor_total) DESC) AS ranking
FROM fato_vendas fv
JOIN dim_produto p ON p.id_produto = fv.id_produto
GROUP BY p.id_produto, p.nome_produto, p.categoria, p.faixa_preco
ORDER BY ranking;

SELECT
    v.nome_vendedor,
    v.regiao_atuacao,
    COUNT(DISTINCT fv.id_pedido) AS pedidos_fechados,
    SUM(fv.valor_total) AS receita_gerada,
    AVG(fv.valor_total) AS ticket_medio
FROM fato_vendas fv
JOIN dim_vendedor v ON v.id_vendedor = fv.id_vendedor
GROUP BY v.id_vendedor, v.nome_vendedor, v.regiao_atuacao
ORDER BY receita_gerada DESC;

SELECT
    c.regiao,
    c.estado,
    COUNT(DISTINCT fv.id_cliente) AS clientes_compradores,
    SUM(fv.valor_total) AS receita,
    AVG(fv.valor_total) AS ticket_medio_item
FROM fato_vendas fv
JOIN dim_cliente c ON c.id_cliente = fv.id_cliente
GROUP BY c.regiao, c.estado
ORDER BY receita DESC;

    COALESCE(p.categoria, '>>> TOTAL GERAL <<<') AS categoria,
    COALESCE(p.nome_produto, ' >> Subtotal Cat.') AS produto,
    SUM(fv.valor_total) AS receita,
    SUM(fv.quantidade) AS unidades
FROM fato_vendas fv
JOIN dim_produto p ON p.id_produto = fv.id_produto
GROUP BY p.categoria, p.nome_produto WITH ROLLUP;

SELECT
    p.categoria,
    SUM(fv.valor_total) AS receita_categoria,
    SUM(SUM(fv.valor_total)) OVER () AS receita_total,
    ROUND(
        100.0 * SUM(fv.valor_total)
        / SUM(SUM(fv.valor_total)) OVER (), 2
    )  AS pct_participacao
FROM fato_vendas fv
JOIN dim_produto p ON p.id_produto = fv.id_produto
GROUP BY p.categoria
ORDER BY receita_categoria DESC;

SELECT
    t.mes,
    t.nome_mes,
    SUM(fv.valor_total) AS receita_mes,
    SUM(SUM(fv.valor_total)) OVER (ORDER BY t.mes) AS receita_acumulada
FROM fato_vendas fv
JOIN dim_tempo t ON t.id_tempo = fv.id_tempo
GROUP BY t.mes, t.nome_mes
ORDER BY t.mes;

SELECT
    t.mes,
    t.nome_mes,
    SUM(fv.valor_total) AS receita_mes,
    LAG(SUM(fv.valor_total)) OVER (ORDER BY t.mes) AS receita_mes_anterior,
    SUM(fv.valor_total)
        - LAG(SUM(fv.valor_total)) OVER (ORDER BY t.mes) AS variacao_absoluta,
    ROUND(100.0 * (
        SUM(fv.valor_total)
        - LAG(SUM(fv.valor_total)) OVER (ORDER BY t.mes)
    ) / NULLIF(LAG(SUM(fv.valor_total)) OVER (ORDER BY t.mes),0), 2) AS variacao_pct
FROM fato_vendas fv
JOIN dim_tempo t ON t.id_tempo = fv.id_tempo
GROUP BY t.mes, t.nome_mes
ORDER BY t.mes;

SELECT
    c.regiao,
    SUM(CASE WHEN p.categoria = 'Eletrônicos' THEN fv.valor_total ELSE 0 END) AS eletronicos,
    SUM(CASE WHEN p.categoria = 'Vestuário' THEN fv.valor_total ELSE 0 END) AS vestuario,
    SUM(CASE WHEN p.categoria = 'Alimentos' THEN fv.valor_total ELSE 0 END) AS alimentos,
    SUM(CASE WHEN p.categoria = 'Livros' THEN fv.valor_total ELSE 0 END) AS livros,
    SUM(CASE WHEN p.categoria = 'Esportes' THEN fv.valor_total ELSE 0 END) AS esportes,
    SUM(fv.valor_total) AS total_regiao
FROM fato_vendas fv
JOIN dim_cliente c ON c.id_cliente = fv.id_cliente
JOIN dim_produto p ON p.id_produto = fv.id_produto
GROUP BY c.regiao
ORDER BY total_regiao DESC;

SELECT
    c.nome_cliente,
    c.cidade,
    c.regiao,
    COUNT(DISTINCT fv.id_pedido) AS total_pedidos,
    SUM(fv.valor_total) AS ltv_total,
    AVG(fv.valor_total) AS ticket_medio,
    MIN(t.data_completa) AS primeira_compra,
    MAX(t.data_completa) AS ultima_compra,
    DATEDIFF(MAX(t.data_completa), MIN(t.data_completa)) AS dias_como_cliente
FROM fato_vendas fv
JOIN dim_cliente c ON c.id_cliente = fv.id_cliente
JOIN dim_tempo t ON t.id_tempo = fv.id_tempo
GROUP BY c.id_cliente, c.nome_cliente, c.cidade, c.regiao
ORDER BY ltv_total DESC;

SELECT
    t.semestre,
    p.faixa_preco,
    COUNT(*) AS transacoes,
    SUM(fv.valor_total) AS receita,
    AVG(fv.valor_total) AS ticket_medio
FROM fato_vendas fv
JOIN dim_produto p ON p.id_produto = fv.id_produto
JOIN dim_tempo t ON t.id_tempo = fv.id_tempo
GROUP BY t.semestre, p.faixa_preco
ORDER BY t.semestre, receita DESC; 

USE db_oltp;

CREATE OR REPLACE VIEW vw_extracao_para_olap AS
SELECT
    p.id_pedido,
    DATE_FORMAT(p.data_pedido, '%Y%m%d') AS id_tempo,
    ip.id_produto,
    p.id_cliente,
    p.id_vendedor,
    ip.quantidade,
    ip.preco_vendido AS preco_unitario,
    (ip.quantidade * ip.preco_vendido) AS valor_total
FROM pedido p
JOIN item_pedido ip ON ip.id_pedido = p.id_pedido
WHERE p.status != 'cancelado';

SELECT * FROM vw_extracao_para_olap ORDER BY id_tempo;

USE db_olap;

